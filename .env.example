# Copy this file to .env and replace the API host with a reachable backend URL.
# For a physical device, use your machine's LAN IP.
# For the Android emulator, 10.0.2.2 maps to your host machine.
EXPO_PUBLIC_API_BASE_URL=http://YOUR_MACHINE_LAN_IP:3000/api
EXPO_PUBLIC_MOCK_MODE=false
EXPO_PUBLIC_ENABLE_SOCKET=true
